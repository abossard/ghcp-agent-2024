{
    // ============================================================
    // VS Code Workspace Settings for Agentic Spring Boot Development
    // Optimized for FSI environment — NO MCP, CLI-focused
    // ============================================================

    // ── Java & Spring Boot Configuration ─────────────────────────
    "java.configuration.updateBuildConfiguration": "automatic",
    "java.compile.nullAnalysis.mode": "automatic",
    "java.autobuild.enabled": true,
    "java.saveActions.organizeImports": true,
    "java.format.enabled": true,
    "java.implementation.codeLens.enabled": true,
    "java.references.codeLens.enabled": true,
    "java.inlayHints.parameterNames.enabled": "all",
    "java.sources.organizeImports.starThreshold": 999,
    "java.sources.organizeImports.staticStarThreshold": 999,
    "java.completion.importOrder": [
        "java",
        "jakarta",
        "javax",
        "org.springframework",
        "com",
        ""
    ],
    "spring-boot.ls.problem.application-properties.UNKNOWN_PROPERTY": "WARNING",

    // ── Editor Behavior ──────────────────────────────────────────
    "editor.formatOnSave": true,
    "editor.formatOnPaste": false,
    "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit"
    },
    "editor.minimap.enabled": false,
    "editor.renderWhitespace": "boundary",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.rulers": [120],
    "editor.wordWrap": "off",
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",

    // ── File Exclusions ──────────────────────────────────────────
    "files.exclude": {
        "**/.classpath": true,
        "**/.factorypath": true,
        "**/.project": true,
        "**/.settings": true,
        "**/target": true,
        "**/.idea": true,
        "**/*.iml": true
    },
    "files.watcherExclude": {
        "**/target/**": true,
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true
    },

    // ── Search Exclusions ────────────────────────────────────────
    "search.exclude": {
        "**/target": true,
        "**/.git": true,
        "**/node_modules": true,
        "**/*.class": true
    },

    // ── Terminal Configuration ────────────────────────────────────
    "terminal.integrated.defaultProfile.windows": "Git Bash",
    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.enableMultiLinePasteWarning": "never",

    // ============================================================
    // GitHub Copilot — Agent Mode Configuration (NO MCP)
    // ============================================================

    // ── Core Copilot Settings ────────────────────────────────────
    "github.copilot.enable": {
        "*": true,
        "yaml": true,
        "markdown": true,
        "java": true,
        "xml": true,
        "properties": true
    },

    // ── Chat & Agent Mode ────────────────────────────────────────
    "chat.commandCenter.enabled": true,
    "chat.agent.enabled": true,
    "chat.agent.maxRequests": 30,

    // ── Instruction Files ────────────────────────────────────────
    "github.copilot.chat.codeGeneration.useInstructionFiles": true,
    "chat.instructionsFilesLocations": {
        ".github/instructions": true
    },

    // ── Prompt Files ─────────────────────────────────────────────
    "chat.promptFiles": true,
    "chat.promptFilesLocations": {
        ".github/prompts": true
    },

    // ── Chat Modes ───────────────────────────────────────────────
    "chat.modeFilesLocations": {
        ".github/chatmodes": true
    },

    // ── Terminal Tool — Auto-Approve Safe Commands ───────────────
    // These are the Java/Spring Boot CLI commands agents can run
    // without manual approval, maximizing agentic flow.
    "github.copilot.chat.tools.terminal.allowlist": [
        "^\\./mvnw (clean|compile|test|package|verify|install|dependency:tree|spring-boot:run|versions:display-dependency-updates)( .*)?$",
        "^mvn (clean|compile|test|package|verify|install|dependency:tree|spring-boot:run)( .*)?$",
        "^java (-version|-jar|--version)( .*)?$",
        "^git (status|log|diff|branch|add|commit|show|stash|remote|fetch|pull|push|checkout|switch|restore|tag|rebase|merge|cherry-pick)( .*)?$",
        "^curl (-s|-v|-X|--silent|--header|--data|http)( .*)?$",
        "^(ls|pwd|cat|head|tail|wc|find|grep|sort|uniq|tr|cut|sed|awk|tee|mkdir|cp|mv|touch|echo|printf|date|whoami|which|where|type|file|du|df)( .*)?$",
        "^(tree|less|more|diff|patch)( .*)?$",
        "^docker (ps|images|logs|inspect|build|run|stop|rm|exec|compose)( .*)?$",
        "^(jps|jstack|jmap|jstat|jinfo|jcmd)( .*)?$"
    ],

    // ── Terminal Tool — Deny Dangerous Commands ──────────────────
    "github.copilot.chat.tools.terminal.denylist": [
        "rm -rf /",
        "rm -rf ~",
        "sudo",
        "format",
        "del /",
        "rmdir /s",
        "mkfs",
        "dd if=",
        ":(){:|:&};:",
        "chmod -R 777",
        "wget.*\\|.*sh",
        "curl.*\\|.*sh"
    ],

    // ── MCP — Explicitly Disabled ────────────────────────────────
    // MCP is blocked by organizational policy. Do NOT configure any MCP servers.
    "github.copilot.chat.agent.thirdParty.autoApprove": false,

    // ── Code Generation Preferences ──────────────────────────────
    "github.copilot.chat.localeOverride": "en",

    // ── Testing ──────────────────────────────────────────────────
    "java.test.defaultConfig": "default",
    "java.test.config": [
        {
            "name": "default",
            "vmArgs": ["-ea"]
        }
    ],

    // ── XML (for pom.xml editing) ────────────────────────────────
    "xml.format.enabled": true,
    "xml.validation.enabled": true,

    // ── Git ──────────────────────────────────────────────────────
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,

    // ── Debugging ────────────────────────────────────────────────
    "java.debug.settings.hotCodeReplace": "auto",
    "java.debug.settings.enableRunDebugCodeLens": true,
    "java.debug.settings.console": "integratedTerminal"
}
